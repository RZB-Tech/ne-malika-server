# Приложение
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5450/nemalika

# Redis (в проде — redis://redis:6379, см. docker-compose.prod.yml)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=changeme-access-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=changeme-refresh-secret
JWT_REFRESH_TTL=30d

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_INIT_DATA_TTL_SEC=86400
# Telegram (дополнение к уже существующим)
TELEGRAM_WEBHOOK_URL=            # публичный HTTPS-адрес, напр. https://api.nemalika.uz/api/v1/bot/webhook
TELEGRAM_WEBHOOK_SECRET=         # секрет для заголовка X-Telegram-Bot-Api-Secret-Token

# S3
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=nemalika
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_BASE=https://nemalika.s3.example.com

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Обязательная переменная: env.validation.ts требует её при старте,
# дефолт из configuration.ts до проверки не доходит.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# LLM re-ranking результатов поиска (true/false)
SEARCH_RERANK_ENABLED=false
